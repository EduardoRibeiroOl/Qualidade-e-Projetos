{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}

/*target: "ES2020" — gera código compatível com o padrão ECMAScript 2020.

module: "commonjs" — usado em projetos Node.js (para require e module.exports).

rootDir: "./src" — indica onde estão seus arquivos .ts.

outDir: "./dist" — onde os arquivos JavaScript compilados serão salvos.

esModuleInterop: permite importar módulos com import express from "express" em vez de import * as express from "express".

strict: ativa todas as verificações de tipo do TypeScript (modo mais seguro).

skipLibCheck: pula a verificação de tipos de bibliotecas externas, para compilar mais rápido.*/